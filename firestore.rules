rules_version = '2';

// =====================================================================
// 영작 트레이너 — Firestore 보안 규칙
// ---------------------------------------------------------------------
// 핵심 원칙
//   1) 허용된 이메일(아래 ALLOWED 목록)만 어떤 데이터든 접근할 수 있다.
//   2) 학생은 '자기 진도'만 읽고 쓴다.
//   3) 스케줄러(streaks)는 모두가 서로 볼 수 있다 → 누가 했는지 보고 독려.
//   4) 선생님(준킴쌤)은 모든 학생 진도를 볼 수 있다.
//
// ▼▼▼ 여기 4줄만 실제 이메일로 바꾸세요 (소문자로) ▼▼▼
//   - 준비되면 아래 따옴표 안의 자리표시자를 진짜 Gmail/구글 계정으로 교체
//   - 교체 후 Firebase 콘솔 > Firestore > 규칙 > '게시' 누르면 끝
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- 허용 이메일 목록 (★ 이 4줄을 바꾸세요) ----
    function teacherEmail() {
      return 'joon.kim@educclesia.com';               // 준킴쌤(관리자)
    }
    function allowedEmails() {
      return [
        'joon.kim@educclesia.com',                    // 준킴쌤 (관리자)
        'creativemeriel@gmail.com',                   // 첫째 (10학년)
        'jasoncanada0506@gmail.com',                  // 둘째 (8학년)
        'elvinkim827@gmail.com'                       // 셋째 (6학년)
      ];
    }
    // ---------------------------------------------

    function isSignedIn()  { return request.auth != null; }
    function email()       { return isSignedIn() ? request.auth.token.email : ''; }
    function isAllowed()   { return isSignedIn() && email() in allowedEmails(); }
    function isTeacher()   { return isSignedIn() && email() == teacherEmail(); }
    function isOwner(uid)  { return isSignedIn() && request.auth.uid == uid; }

    // ── 학생 개인 데이터: 본인 + 선생님만 ──────────────────────────
    match /members/{uid} {
      allow read:  if isAllowed() && (isOwner(uid) || isTeacher());
      allow write: if isAllowed() && isOwner(uid);

      // 진도 / 일일 기록 / 승급 시험 결과 (하위 컬렉션)
      match /{sub=**} {
        allow read:  if isAllowed() && (isOwner(uid) || isTeacher());
        allow write: if isAllowed() && isOwner(uid);
      }
    }

    // ── 스케줄러(묵상집): 모두 열람 가능, 쓰기는 본인만 ──────────────
    // streaks/{uid} = { name, grade, level, todayDone, lastDate,
    //                   streak, week:{mon..sun}, totalSentences, updatedAt }
    match /streaks/{uid} {
      allow read:  if isAllowed();                    // 서로 보고 독려
      allow write: if isAllowed() && isOwner(uid);
    }

    // ── 응원 보내기 (선택): 허용된 사람끼리 ─────────────────────────
    match /cheers/{cheerId} {
      allow read:   if isAllowed();
      allow create: if isAllowed() && request.resource.data.from == email();
      allow update, delete: if false;                 // 응원은 수정/삭제 불가
    }

    // ── 그 외 전부 차단 ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
