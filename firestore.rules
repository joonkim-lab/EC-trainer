rules_version = '2';

// =====================================================================
// 쌉가능 (영작 트레이너) — Firestore 보안 규칙
// ---------------------------------------------------------------------
//   1) 허용된 이메일(allowedEmails)만 데이터에 접근할 수 있다.
//   2) 학생은 자기 진도만 읽고 쓴다.
//   3) 스케줄러(streaks)는 모두 서로 볼 수 있다.
//   4) 선생님(teacherEmails)은 모든 학생 진도를 읽고 쓴다.
//
// ▼ 사람이 바뀌면 아래 두 목록만 고치고 콘솔에서 '게시' 하세요 (소문자) ▼
//   - allowedEmails 에는 선생님·학생 '모두'를 넣어야 함 (여기가 로그인 관문)
//   - teacherEmails 에는 선생님만
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- 허용 이메일 (선생님 + 학생 전부. 로그인 관문) ----
    function allowedEmails() {
      return [
        // 선생님
        'joon.kim@educclesia.com',
        'judy.hong@eliteopenschool.org',
        'eunji.ahn@eliteopenschool.org',
        'jeein.kang@eliteopenschool.org',
        'sol.park@eliteopenschool.org',
        // 학생
        'creativemeriel@gmail.com',
        'jasoncanada0506@gmail.com',
        'elvinkim827@gmail.com'
      ];
    }

    // ---- 선생님만 ----
    function teacherEmails() {
      return [
        'joon.kim@educclesia.com',
        'judy.hong@eliteopenschool.org',
        'eunji.ahn@eliteopenschool.org',
        'jeein.kang@eliteopenschool.org',
        'sol.park@eliteopenschool.org'
      ];
    }
    // ---------------------------------------------

    function isSignedIn()  { return request.auth != null; }
    function email()       { return isSignedIn() ? request.auth.token.email : ''; }
    function isAllowed()   { return isSignedIn() && email() in allowedEmails(); }
    function isTeacher()   { return isSignedIn() && email() in teacherEmails(); }
    function isOwner(uid)  { return isSignedIn() && request.auth.uid == uid; }

    // ── 학생 개인 데이터: 본인 + 선생님 ──
    match /members/{uid} {
      allow read:  if isAllowed() && (isOwner(uid) || isTeacher());
      allow write: if isAllowed() && (isOwner(uid) || isTeacher());

      match /{sub=**} {
        allow read:  if isAllowed() && (isOwner(uid) || isTeacher());
        allow write: if isAllowed() && (isOwner(uid) || isTeacher());
      }
    }

    // ── 스케줄러: 모두 열람, 쓰기는 본인만 ──
    match /streaks/{uid} {
      allow read:  if isAllowed();
      allow write: if isAllowed() && isOwner(uid);
    }

    // ── 응원(선택) ──
    match /cheers/{cheerId} {
      allow read:   if isAllowed();
      allow create: if isAllowed() && request.resource.data.from == email();
      allow update, delete: if false;
    }

    // ── 그 외 전부 차단 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
